<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Rule Maven" suffix=" · Rule Maven" phx-no-format>{assigns[:page_title]}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css?v=#{css_version()}"} />
    <link rel="manifest" href={~p"/manifest.json"} />
    <link rel="apple-touch-icon" href={~p"/images/icon-192.svg"} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <script>
      // Map retired theme slugs to their current (kebab-of-label) names, so a
      // saved theme survives a rename. Shared with the picker script. Lookup is
      // one hop, so slugs from *any* past generation must point straight at a
      // live slug — never at another key in this map.
      window.__themeMigrate = {
        // pre-rename originals
        ocean: 'kraken', forest: 'overgrowth', retro: 'mixtape',
        scary: 'grave-digger', sunset: 'last-turn', happy: 'lemonade',
        light: 'fresh-deck', dark: 'night-owl', scifi: 'deep-space',
        matrix: 'cheat-code', fantasy: 'dungeon-master',
        // one-word era
        abyss: 'kraken', arcade: 'insert-coin', brass: 'steamworks',
        canopy: 'overgrowth', cassette: 'mixtape', coral: 'flamingo',
        crypt: 'grave-digger', dusk: 'last-turn', ember: 'campfire',
        frost: 'snow-day', 'golden-hour': 'lemonade', honey: 'honeycomb',
        lavender: 'fresh-deck', marble: 'chess-club', meadow: 'picnic',
        midnight: 'night-owl', nebula: 'deep-space', neon: 'cheat-code',
        parchment: 'dungeon-master', twilight: 'moonrise', void: 'black-hole'
      };
      (function() {
        var html = document.documentElement;
        var saved = localStorage.getItem('theme');
        if (saved) {
          var migrated = window.__themeMigrate[saved] || saved;
          if (migrated !== saved) localStorage.setItem('theme', migrated);
          html.setAttribute('data-theme', migrated);
        } else {
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          html.setAttribute('data-theme', prefersDark ? 'night-owl' : 'fresh-deck');
        }
        // Apply the saved ambient-motion preference before paint to avoid a flash.
        if (localStorage.getItem('motion') === 'off') {
          html.setAttribute('data-motion', 'off');
        }
      })();
    </script>
    <%!-- ?v= mtime busters: same reason as app.css above — un-digested
          assets + heuristic HTTP caching replay stale JS on plain refresh
          (hooks silently missing after a deploy). --%>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/phoenix.js?v=#{asset_version("assets/js/phoenix.js")}"}
    >
    </script>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/phoenix_html.js?v=#{asset_version("assets/js/phoenix_html.js")}"}
    >
    </script>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={
        ~p"/assets/js/phoenix_live_view.js?v=#{asset_version("assets/js/phoenix_live_view.js")}"
      }
    >
    </script>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/app.js?v=#{js_version()}"}
    >
    </script>
  </head>
  <body>
    <div class="phx-disconnected-text">Lost connection. Retrying...</div>
    <div class="app-shell">
      <header class="header">
        <div class="header-inner">
          <a href={~p"/"} class="header-brand">
            <span class="header-icon">🎲</span>
            <%!-- Mobile stacks "Rule" over "Maven" (see the 768px block) so the
                  theme picker beside it can show a full theme name. --%>
            <span class="header-title">Rule <span class="header-title-accent">Maven</span></span>
          </a>

          <% me =
            assigns[:current_user] || (assigns[:conn] && assigns[:conn].assigns[:current_user]) ||
              (assigns[:conn] && RuleMavenWeb.Layouts.current_user(assigns[:conn])) %>

          <%= if me && RuleMaven.Users.can?(me, :admin) do %>
            <button class="hamburger" id="hamburger-btn" aria-label="Menu">
              <span></span><span></span><span></span>
            </button>
          <% end %>

          <!-- Desktop nav -->
          <nav class="header-nav" id="header-nav">
            <%= if me && RuleMaven.Users.can?(me, :admin) do %>
              <.link href={~p"/admin"} class="nav-link">Dashboard</.link>
              <details class="user-dropdown">
                <summary class="user-dropdown-toggle nav-link">Admin</summary>
                <div class="user-dropdown-menu" style="left:0;right:auto;min-width:160px">
                  <div class="user-dropdown-section">Review</div>
                  <.link href={~p"/admin/questions"} class="user-dropdown-link">Questions</.link>
                  <.link href={~p"/admin/moderation"} class="user-dropdown-link">Moderation</.link>
                  <.link href={~p"/admin/audit"} class="user-dropdown-link">Audit Log</.link>
                  <.link href={~p"/admin/takedowns"} class="user-dropdown-link">Takedowns</.link>
                  <div class="user-dropdown-section">Manage</div>
                  <.link href={~p"/admin/users"} class="user-dropdown-link">Users</.link>
                  <.link href={~p"/admin/invites"} class="user-dropdown-link">Invites</.link>
                  <.link href={~p"/admin/catalog"} class="user-dropdown-link">Catalog</.link>
                  <.link href={~p"/admin/requests"} class="user-dropdown-link">Requests</.link>
                  <div class="user-dropdown-section">System</div>
                  <.link href={~p"/admin/flags"} class="user-dropdown-link">Feature Flags</.link>
                  <.link href={~p"/admin/health"} class="user-dropdown-link">Health</.link>
                  <.link href={~p"/admin/usage"} class="user-dropdown-link">Usage &amp; Cost</.link>
                  <.link href={~p"/admin/security"} class="user-dropdown-link">Security</.link>
                  <.link href={~p"/admin/db"} class="user-dropdown-link">DB Admin</.link>
                  <.link href={~p"/admin/themes"} class="user-dropdown-link">Themes</.link>
                  <.link href={~p"/standing"} class="user-dropdown-link">Standing</.link>
                  <.link href={~p"/groups"} class="user-dropdown-link">My Groups</.link>
                  <.link href={~p"/settings"} class="user-dropdown-link">Settings</.link>
                  <.link href={~p"/oban"} class="user-dropdown-link" target="_blank">Oban ↗</.link>
                </div>
              </details>
            <% end %>
          </nav>

          <div class="header-right">
            <div class="header-controls">
              <select
                class="theme-select"
                id="game-theme-select"
                aria-label="Game theme"
                title="Match this game's colors"
                hidden
              >
                <option value="0">🖌️ Off</option>
                <option :for={{slug, label} <- RuleMaven.Metrics.game_themes()} value={slug}>
                  🖌️ {label}
                </option>
              </select>
              <select
                class="theme-select"
                id="theme-select"
                aria-label="Theme"
                title="Change the site's color theme"
              >
                <optgroup
                  :for={{scheme, entries} <- RuleMaven.Metrics.themes_by_scheme()}
                  label={if scheme == :light, do: "Light", else: "Dark"}
                >
                  <option :for={{slug, label} <- entries} value={slug}>
                    🎨 {label}
                  </option>
                </optgroup>
              </select>
              <%!-- Signed-in users get this inside the account menu instead —
                    the mobile header has no room for it. Signed-out visitors
                    have no menu, so it stays in the header for them. Exactly one
                    #motion-toggle is ever rendered; the script binds by id. --%>
              <button
                :if={!me}
                type="button"
                class="motion-toggle"
                id="motion-toggle"
                aria-pressed="false"
                aria-label="Toggle ambient animations"
                title="Turn ambient animations on/off"
              >
                <span class="motion-toggle-on">✨</span>
                <span class="motion-toggle-off">🌙</span>
              </button>
            </div>

            <%= cond do %>
              <% me -> %>
                <details class="user-dropdown">
                  <summary class="user-dropdown-toggle" aria-label="Account menu">
                    <%!-- .header-user is hidden under 768px, which used to leave
                          this summary empty — an invisible control that was a
                          signed-in visitor's only route to Settings/Log out. --%>
                    <span class="header-user-icon" aria-hidden="true">👤</span>
                    <span class="header-user">{me.username}</span>
                    <%!-- Outside .header-user, which is display:none under 768px:
                          the badge is the only signal of an elevated session, so
                          it must survive the mobile collapse the username doesn't. --%>
                    <RuleMavenWeb.CoreComponents.role_badge user={me} />
                  </summary>
                  <div class="user-dropdown-menu">
                    <div class="user-dropdown-section">Display</div>
                    <button
                      type="button"
                      class="user-dropdown-link motion-toggle motion-toggle--menu"
                      id="motion-toggle"
                      aria-pressed="false"
                      aria-label="Toggle ambient animations"
                    >
                      <%!-- The label names the ACTION, not the state: the span
                            shown while animations are on offers to turn them
                            off. No emoji — the sibling links have no icon
                            column, and a leading glyph would push this row's
                            label out of their shared left edge. --%>
                      <span class="motion-toggle-on">Turn animations off</span>
                      <span class="motion-toggle-off">Turn animations on</span>
                    </button>
                    <div class="user-dropdown-section">Account</div>
                    <.link href={~p"/standing"} class="user-dropdown-link">Standing</.link>
                    <.link href={~p"/groups"} class="user-dropdown-link">My Groups</.link>
                    <.link href={~p"/settings"} class="user-dropdown-link">Settings</.link>
                    <.link href={~p"/help"} class="user-dropdown-link">Help &amp; FAQ</.link>
                    <div class="user-dropdown-section">Tours</div>
                    <a href={~p"/"} class="user-dropdown-link" data-tour-replay="games">
                      🧭 Finding games
                    </a>
                    <a href={~p"/"} class="user-dropdown-link" data-tour-replay="game">
                      🧭 Asking questions
                    </a>
                    <a href={~p"/"} class="user-dropdown-link" data-tour-replay="answer">
                      🧭 Understanding answers
                    </a>
                    <.link href={~p"/logout"} class="user-dropdown-link">Log out</.link>
                  </div>
                </details>
              <% true -> %>
                <.link href={~p"/register"} class="nav-link" style="color:var(--text-muted)">Register</.link>
                <.link href={~p"/login"} class="nav-link">Log in</.link>
            <% end %>
          </div>
        </div>
      </header>

      <!-- Mobile drawer overlay -->
      <div class="drawer-overlay" id="drawer-overlay"></div>
      <div class="drawer" id="drawer">
        <div class="drawer-header">
          <span class="drawer-title">Menu</span>
          <button class="drawer-close" id="drawer-close" aria-label="Close menu">&times;</button>
        </div>
        <nav class="drawer-nav">
          <.link href={~p"/"} class="drawer-link">🏠 Home</.link>
          <%= if me && RuleMaven.Users.can?(me, :admin) do %>
            <div class="drawer-section">Admin</div>
            <.link href={~p"/admin"} class="drawer-link">Dashboard</.link>
            <div class="drawer-section">Review</div>
            <.link href={~p"/admin/questions"} class="drawer-link">Questions</.link>
            <.link href={~p"/admin/moderation"} class="drawer-link">Moderation</.link>
            <.link href={~p"/admin/audit"} class="drawer-link">Audit Log</.link>
            <.link href={~p"/admin/takedowns"} class="drawer-link">DMCA Takedowns</.link>
            <div class="drawer-section">Manage</div>
            <.link href={~p"/admin/users"} class="drawer-link">Manage Users</.link>
            <.link href={~p"/admin/invites"} class="drawer-link">Invite Codes</.link>
            <.link href={~p"/admin/catalog"} class="drawer-link">Game Catalog</.link>
            <.link href={~p"/admin/requests"} class="drawer-link">Support Requests</.link>
            <div class="drawer-section">System</div>
            <.link href={~p"/admin/flags"} class="drawer-link">Feature Flags</.link>
            <.link href={~p"/admin/health"} class="drawer-link">System Health</.link>
            <.link href={~p"/admin/usage"} class="drawer-link">Usage &amp; Cost</.link>
            <.link href={~p"/admin/security"} class="drawer-link">Security</.link>
            <.link href={~p"/admin/db"} class="drawer-link">DB Admin</.link>
            <.link href={~p"/admin/themes"} class="drawer-link">Theme Usage</.link>
            <.link href={~p"/settings"} class="drawer-link">Settings</.link>
            <.link href={~p"/oban"} class="drawer-link" target="_blank">Oban Dashboard ↗</.link>
          <% end %>
          <div class="drawer-section"></div>
          <.link href={~p"/help"} class="drawer-link">📖 Help &amp; FAQ</.link>
          <%= if me do %>
            <.link href={~p"/standing"} class="drawer-link">Standing</.link>
            <.link href={~p"/groups"} class="drawer-link">My Groups</.link>
            <.link href={~p"/logout"} class="drawer-link">Log out</.link>
          <% else %>
            <.link href={~p"/login"} class="drawer-link">Log in</.link>
            <.link href={~p"/register"} class="drawer-link">Register</.link>
          <% end %>
        </nav>
      </div>

      <%!-- LiveView routes render their own flash_group via the live layout
            (RuleMavenWeb.Layouts.app), which re-renders on every connected
            update — this root-layout flash_group is dead-rendered once and
            never updates after the socket connects, so it's skipped here to
            avoid a duplicate, stale flash box. Controller routes (e.g. login)
            have no live layout, so they keep using this one. --%>
      <%= if !(assigns[:conn] && assigns[:conn].private[:phoenix_live_view]) do %>
        <.flash_group flash={assigns[:flash] || %{}} />
      <% end %>

      <main class="main-content">
        <div class="container">
          {@inner_content}
        </div>
      </main>

      <%!-- Persistent admin-only background-job panel. Rendered in the root
            layout (not the app layout) so it stays mounted across live
            navigation; gated to admins. --%>
      <% panel_user =
        assigns[:current_user] || (assigns[:conn] && assigns[:conn].assigns[:current_user]) ||
          (assigns[:conn] && RuleMavenWeb.Layouts.current_user(assigns[:conn])) %>
      <%= if assigns[:conn] && panel_user && RuleMaven.Users.can?(panel_user, :admin) do %>
        {live_render(@conn, RuleMavenWeb.AdminLive.JobPanel, id: "job-panel")}
      <% end %>
    </div>

    <script>
      (function() {
        var select = document.getElementById('theme-select');
        // Hidden source of the game-theme <option>s only. The single visible
        // control is #theme-select; on game pages the game options fold into it
        // as a top optgroup — one theme menu on every screen size.
        var gameSource = document.getElementById('game-theme-select');
        var html = document.documentElement;

        // True when the current page exposes a per-game palette (the Q&A/FAQ
        // pages inject `#game-theme`). Game options only appear then.
        function gameThemeAvailable() {
          return !!document.getElementById('game-theme');
        }

        // The user's static theme — the look used everywhere a game palette
        // isn't active. Never holds "game-light"/"game-dark".
        function baseTheme() {
          var s = localStorage.getItem('theme');
          if (s) {
            var migrate = window.__themeMigrate || {};
            return migrate[s] || s;
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'night-owl' : 'fresh-deck';
        }

        function isGameTheme(v) {
          return v === 'game-light' || v === 'game-dark';
        }

        // Broadcast the effective game-match so in-page opt-in UI (the overview
        // "Dress this page" button) can show/hide itself in sync — e.g. reappear
        // when the picker is switched back to Off.
        function announceMatch(match) {
          window.dispatchEvent(new CustomEvent('rm:gametheme', {
            detail: { match: isGameTheme(match) ? match : '0' }
          }));
        }

        // Fold the game-theme options into the single site picker as a pinned
        // top optgroup whenever the page offers a palette — same control on
        // every screen size, so there's just one theme menu to learn.
        // The game's own names for its two variants, generated with its palette
        // and published on the #game-theme marker. Absent for palettes made
        // before names existed — the static "Game Light"/"Game Dark" stand in.
        function gameVariantLabel(value) {
          var marker = document.getElementById('game-theme');
          if (!marker) return null;
          var attr = value === 'game-light' ? 'data-light-name' : 'data-dark-name';
          var name = marker.getAttribute(attr);
          return name && name.trim() ? name.trim() : null;
        }

        function syncGameOptions(available) {
          var group = document.getElementById('theme-select-game-group');
          if (!available) {
            if (group) group.remove();
            return;
          }
          if (!group) {
            group = document.createElement('optgroup');
            group.id = 'theme-select-game-group';
            group.label = 'Match game';
            Array.prototype.forEach.call(gameSource.options, function(opt) {
              if (opt.value === '0') return;
              var clone = opt.cloneNode(true);
              // Stash the generic label ("🖌️ Game Light") to fall back to on a
              // game whose palette carries no names.
              clone.dataset.defaultLabel = opt.textContent.trim();
              group.appendChild(clone);
            });
            // Pin to the TOP: buried under 20+ site themes the game options
            // were effectively invisible. First thing you see now.
            select.insertBefore(group, select.firstChild);
          }
          // Relabel on EVERY sync, not just on create: the group survives a
          // LiveView navigation from one game to the next, and would otherwise
          // still be advertising the previous game's variant names.
          Array.prototype.forEach.call(group.children, function(opt) {
            var name = gameVariantLabel(opt.value);
            // textContent, never innerHTML — these names are model-authored.
            opt.textContent = name ? '🖌️ ' + name : opt.dataset.defaultLabel;
          });
        }

        // Sync the picker and active theme to the current page: the chosen game
        // variant wins on pages that offer one; otherwise the static theme.
        // Re-run after LiveView navigations because the per-game `#game-theme`
        // style block comes and goes.
        function syncTheme() {
          var base = baseTheme();
          localStorage.setItem('theme', base);
          var available = gameThemeAvailable();
          syncGameOptions(available);

          var match = localStorage.getItem('themeGameMatch');
          if (available && isGameTheme(match)) {
            html.setAttribute('data-theme', match);
            select.value = match;
          } else {
            html.setAttribute('data-theme', base);
            select.value = base;
          }
          announceMatch(match);
        }

        syncTheme();
        // LiveView swaps page content without a full reload; re-sync so leaving a
        // game page can't strand us on the now-undefined game theme.
        window.addEventListener('phx:page-loading-stop', syncTheme);
        // Regenerating a palette from the Prepare page swaps the #game-theme
        // marker (and its names) via a server push — no page-loading-stop. Pick
        // the fresh names up whenever the picker is actually opened.
        ['focus', 'pointerdown'].forEach(function(evt) {
          select.addEventListener(evt, function() {
            syncGameOptions(gameThemeAvailable());
          });
        });

        function track(value) {
          var meta = document.querySelector('meta[name="csrf-token"]');
          fetch('/theme-events', {
            method: 'POST',
            headers: {
              'content-type': 'application/json',
              'x-csrf-token': meta ? meta.getAttribute('content') : ''
            },
            body: JSON.stringify({ theme: value })
          }).catch(function() {});
        }

        // The single theme picker. On a game page its game options switch on a
        // game variant, and any other option is the explicit off-switch for that
        // variant. Off a game page there are no game options here, so a standing
        // game selection is preserved and wins again on return to that game.
        select.addEventListener('change', function() {
          if (isGameTheme(this.value)) {
            localStorage.setItem('themeGameMatch', this.value);
            html.setAttribute('data-theme', this.value);
            announceMatch(this.value);
            track(this.value);
            return;
          }
          localStorage.setItem('theme', this.value);
          if (gameThemeAvailable()) {
            localStorage.setItem('themeGameMatch', '0');
            announceMatch('0');
          }
          html.setAttribute('data-theme', this.value);
          track(this.value);
        });

        // Ambient-animation toggle.
        var motionBtn = document.getElementById('motion-toggle');
        if (motionBtn) {
          function syncMotion() {
            var off = localStorage.getItem('motion') === 'off';
            html.setAttribute('data-motion', off ? 'off' : 'on');
            motionBtn.setAttribute('aria-pressed', off ? 'true' : 'false');
          }
          syncMotion();
          motionBtn.addEventListener('click', function() {
            var off = localStorage.getItem('motion') === 'off';
            localStorage.setItem('motion', off ? 'on' : 'off');
            syncMotion();
          });
        }
      })();
    </script>
  </body>
</html>
