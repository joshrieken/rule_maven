{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_TOOL_INPUT_COMMAND\" in *git\\ commit*) bash .claude/hooks/check-agents-docs.sh ;; esac"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-setup.sh",
            "async": true,
            "timeout": 600,
            "statusMessage": "Setting up worktree (env files, deps, compile)..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "deps",
      "node_modules",
      "priv/browser",
      "priv/docling/.venv",
      "priv/static/rulebooks",
      "priv/static/uploads"
    ]
  }
}
